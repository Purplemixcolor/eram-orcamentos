generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  ORCAMENTISTA
  REVISOR
  CONSULTA
}

enum ReviewStatus {
  PENDING
  REVIEWED
  APPROVED
  INCOMPLETE
  DUPLICATE
}

enum QuoteStatus {
  RASCUNHO
  EM_ANALISE
  AGUARDANDO_APROVACAO
  APROVADO_INTERNAMENTE
  ENVIADO_AO_CLIENTE
  APROVADO_PELO_CLIENTE
  REJEITADO
  CANCELADO
  CONVERTIDO_EM_SERVICO
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  active       Boolean    @default(true)
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([roleId])
}

model Role {
  id          String       @id @default(cuid())
  name        RoleName     @unique
  users       User[]
  permissions Permission[]
}

model Permission {
  id        String @id @default(cuid())
  action    String
  subject   String
  roleId    String
  role      Role   @relation(fields: [roleId], references: [id])

  @@unique([action, subject, roleId])
}

model ServiceCategory {
  id            String               @id @default(cuid())
  name          String               @unique
  active        Boolean              @default(true)
  sortOrder     Int                  @default(0)
  subcategories ServiceSubcategory[]
  records       ServiceRecord[]
}

model ServiceSubcategory {
  id         String          @id @default(cuid())
  name       String
  active     Boolean         @default(true)
  categoryId String
  category   ServiceCategory @relation(fields: [categoryId], references: [id])
  records    ServiceRecord[]

  @@unique([name, categoryId])
}

model Vessel {
  id                 String          @id @default(cuid())
  name               String
  previousName       String?
  type               String
  currentShipownerId String?
  currentShipowner   Shipowner?      @relation(fields: [currentShipownerId], references: [id])
  registration       String?
  imo                String?
  dimensions         String?
  builtYear          Int?
  observations       String?
  serviceRecords     ServiceRecord[]
  quotes             Quote[]

  @@index([name])
  @@index([currentShipownerId])
}

model Shipowner {
  id             String          @id @default(cuid())
  legalName      String
  tradeName      String
  cnpj           String?
  contacts       Json?
  internalStatus String          @default("Ativo")
  observations   String?
  vessels        Vessel[]
  serviceRecords ServiceRecord[]
  quotes         Quote[]

  @@index([tradeName])
  @@index([cnpj])
}

model ServiceRecord {
  id                     String              @id @default(cuid())
  internalCode           String              @unique
  title                  String
  description            String
  keywords               String[]
  vesselId               String?
  vessel                 Vessel?             @relation(fields: [vesselId], references: [id])
  shipownerId            String?
  shipowner              Shipowner?          @relation(fields: [shipownerId], references: [id])
  categoryId             String?
  category               ServiceCategory?    @relation(fields: [categoryId], references: [id])
  subcategoryId          String?
  subcategory            ServiceSubcategory? @relation(fields: [subcategoryId], references: [id])
  year                   Int?
  executionDate          DateTime?
  quoteDate              DateTime?
  quoteNumber            String?
  workOrderNumber        String?
  quantity               Decimal?            @db.Decimal(12, 3)
  unit                   String?
  originalUnitValue      Decimal             @db.Decimal(14, 2)
  originalTotalValue     Decimal             @db.Decimal(14, 2)
  currency               String              @default("BRL")
  materialsIncluded      Boolean             @default(false)
  laborIncluded          Boolean             @default(true)
  estimatedHours         Decimal?            @db.Decimal(10, 2)
  actualHours            Decimal?            @db.Decimal(10, 2)
  sector                 String?
  estimator              String?
  observations           String?
  serviceStatus          String?
  source                 String
  sourcePath             String?
  sourceReference        String?
  importedAt             DateTime            @default(now())
  importedBy             String?
  reliability            String              @default("Media")
  reviewStatus           ReviewStatus        @default(PENDING)
  local                  String?
  material               String?
  attachments            Attachment[]
  quoteItems             QuoteItem[]
  dataReviews            DataReview[]
  tags                   Tag[]               @relation("ServiceRecordTags")

  @@index([title])
  @@index([year])
  @@index([quoteNumber])
  @@index([workOrderNumber])
  @@index([reviewStatus])
  @@index([source])
  @@index([vesselId])
  @@index([shipownerId])
  @@index([categoryId])
}

model Quote {
  id                   String          @id @default(cuid())
  number               String          @unique
  shipownerId          String?
  shipowner            Shipowner?      @relation(fields: [shipownerId], references: [id])
  vesselId             String?
  vessel               Vessel?         @relation(fields: [vesselId], references: [id])
  responsible          String
  createdAt            DateTime        @default(now())
  validUntil           DateTime?
  status               QuoteStatus     @default(RASCUNHO)
  observations         String?
  commercialConditions String?
  serviceTotal         Decimal         @default(0) @db.Decimal(14, 2)
  materialTotal        Decimal         @default(0) @db.Decimal(14, 2)
  taxes                Decimal         @default(0) @db.Decimal(14, 2)
  discounts            Decimal         @default(0) @db.Decimal(14, 2)
  margin               Decimal         @default(0) @db.Decimal(6, 2)
  total                Decimal         @default(0) @db.Decimal(14, 2)
  versions             QuoteVersion[]
  items                QuoteItem[]
  approvals            QuoteApproval[]

  @@index([number])
  @@index([status])
}

model QuoteVersion {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id])
  version   Int
  snapshot  Json
  createdAt DateTime @default(now())

  @@unique([quoteId, version])
}

model QuoteItem {
  id                     String         @id @default(cuid())
  quoteId                String
  quote                  Quote          @relation(fields: [quoteId], references: [id])
  serviceRecordId        String?
  serviceRecord          ServiceRecord? @relation(fields: [serviceRecordId], references: [id])
  description            String
  quantity               Decimal        @db.Decimal(12, 3)
  unit                   String
  value                  Decimal        @db.Decimal(14, 2)
  materials              String?
  hours                  Decimal?       @db.Decimal(10, 2)
  margin                 Decimal?       @db.Decimal(6, 2)
  observations           String?
  historicalOriginalValue Decimal?      @db.Decimal(14, 2)
}

model QuoteApproval {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id])
  approver  String
  status    String
  comment   String?
  createdAt DateTime @default(now())
}

model Attachment {
  id              String         @id @default(cuid())
  filename        String
  storageKey      String
  mimeType        String?
  serviceRecordId String?
  serviceRecord   ServiceRecord? @relation(fields: [serviceRecordId], references: [id])
  sourceDocumentId String?
  sourceDocument  SourceDocument? @relation(fields: [sourceDocumentId], references: [id])
  createdAt       DateTime       @default(now())
}

model ImportJob {
  id          String        @id @default(cuid())
  source      String
  adapter     String        @default("RasnickImportAdapter")
  status      String
  progress    Int           @default(0)
  accepted    Int           @default(0)
  rejected    Int           @default(0)
  duplicates  Int           @default(0)
  batches     ImportBatch[]
  errors      ImportError[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ImportBatch {
  id          String    @id @default(cuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id])
  batchNumber Int
  status      String
  accepted    Int       @default(0)
  rejected    Int       @default(0)
  duplicates  Int       @default(0)
}

model ImportError {
  id          String    @id @default(cuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id])
  rowNumber   Int?
  message     String
  payload     Json?
  createdAt   DateTime  @default(now())
}

model SourceDocument {
  id          String       @id @default(cuid())
  source      String
  originalKey String
  checksum    String?
  attachments Attachment[]
  createdAt   DateTime     @default(now())
}

model SavedFilter {
  id        String   @id @default(cuid())
  name      String
  userId    String
  config    Json
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  targetType  String
  targetId    String
  beforeValue Json?
  afterValue  Json?
  origin      String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

model DataReview {
  id              String        @id @default(cuid())
  serviceRecordId String
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id])
  status          ReviewStatus
  note            String?
  reviewer        String?
  createdAt       DateTime      @default(now())
}

model Tag {
  id      String          @id @default(cuid())
  name    String          @unique
  records ServiceRecord[] @relation("ServiceRecordTags")
}
